{
    "name": "nitro-next",
    "packageManager": "yarn@4.15.0",
    "private": true,
    "type": "module",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "build": "npx update-browserslist-db@latest && yarn workspaces foreach --all -pt run build",
        "typecheck": "yarn workspaces foreach --all -pt run typecheck",
        "lint": "yarn workspaces foreach --all -pt run lint",
        "clean": "yarn workspaces foreach --all -pt run clean",
        "dev": "yarn workspace @nitrodevco/nitro-react dev"
    },
    "dependencies": {
        "pixi.js": "^8.18.1"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "globals": "^17.6.0",
        "typescript": "^5.9.3"
    }
}
