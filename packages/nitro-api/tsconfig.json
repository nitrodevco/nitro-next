{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "paths": {
            "#api/asset/*": [
                "./src/asset/*"
            ],
            "#api/avatar/*": [
                "./src/avatar/*"
            ],
            "#api/communication/*": [
                "./src/communication/*"
            ],
            "#api/events/*": [
                "./src/events/*"
            ],
            "#api/room/*": [
                "./src/room/*"
            ],
            "#api/session/*": [
                "./src/session/*"
            ],
            "#api/utils/*": [
                "./src/utils/*"
            ],
            "#api/*": [
                "./src/*"
            ],
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "dist",
        "node_modules"
    ]
}