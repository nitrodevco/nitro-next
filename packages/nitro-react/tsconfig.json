{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "noEmit": true,
        "jsx": "react-jsx",
        "types": [
            "node"
        ],
        "paths": {
            "#base/components": [
                "./src/components/index.ts"
            ],
            "#base/context": [
                "./src/context/index.ts"
            ],
            "#base/handlers": [
                "./src/handlers/index.ts"
            ],
            "#base/hooks": [
                "./src/hooks/index.ts"
            ],
            "#base/stores": [
                "./src/stores/index.ts"
            ],
            "#base/utils": [
                "./src/utils/index.ts"
            ],
            "#base/*": [
                "./src/*"
            ],
            "#themes/*": [
                "./themes/*"
            ]
        },
    },
    "references": [
        {
            "path": "../nitro-api"
        },
        {
            "path": "../nitro-renderer"
        },
        {
            "path": "../nitro-shared"
        },
    ],
    "include": [
        "src/**/*",
        "themes/**/*",
        "vite.config.ts",
        "postcss.config.js",
        "tailwind.config.js",
        "eslint.config.js"
    ],
    "exclude": [
        "dist",
        "node_modules"
    ]
}