{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "types": [
            "node"
        ],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": false,
        "strictNullChecks": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "allowJs": true,
        "composite": true,
    }
}